@inproceedings{A_Survey_of_IoT_Platform_Comparison_for_Building_Cyber-Physical_System_Architecture,
	author={Yohanes Yohanie Fridelin Panduman and Sritrusta Sukaridhoto and Anang Tjahjono},
	year={2019},
	title={{A Survey of IoT Platform Comparison for Building Cyber-Physical System Architecture}},
	booktitle={- 2019 International Seminar on Research of Information Technology and Intelligent Systems (ISRITI)},
	pages={238-243},
	note={ID: 1},
	abstract={Increased Internet of Things (IoT) technology has increased the number of IoT platform technology developments that are used to facilitate the development of IoT. But in the industrial era 4.0, the application of IoT to Smart Factory has evolved into a new paradigm, namely the Cyber-Physical System (CPS). Therefore, this paper aims to do a survey to determine the parameters and criteria to build a system and architecture of the CPS platform. Additionally, it surveys and analyzes using several parameters or criteria to compare several IoT platforms such as thing management, connectivity, data storage, data abstraction, interface, analytical, feedback & collaboration, security, scalability, microservices, plug, and play. The result shows that these parameters and criteria can be used as references to develop the CPS platform system. In the next step, we expected that the creation of a CPS platform can be based on references from the results of this research survey and analysis.},
	isbn={NULL-},
	language={English},
	url={https://ieeexplore.ieee.org/document/9034650},
	doi={10.1109/ISRITI48646.2019.9034650}
}
